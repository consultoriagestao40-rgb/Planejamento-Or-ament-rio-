generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("POSTGRES_PRISMA_URL") // Uses connection pooling
}

model Tenant {
  id           String   @id @default(uuid())
  name         String
  cnpj         String   @unique
  accessToken  String?
  refreshToken String?
  tokenExpiresAt DateTime?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  taxRate      Float    @default(0) // Default tax rate for DAS calculation
  
  budgets      BudgetEntry[]
  realized     RealizedEntry[]
  categories   Category[]
  costCenters  CostCenter[]
  userAccess   UserTenantAccess[]
  locks        CostCenterLock[]
  radarLocks   RadarLock[]
}

model RadarLock {
  id           String   @id @default(uuid())
  tenantId     String
  month        Int      // 1-12
  year         Int
  isLocked     Boolean  @default(false)
  deadline     DateTime? // Optional automatic locking deadline
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  tenant       Tenant   @relation(fields: [tenantId], references: [id])

  @@unique([tenantId, month, year])
}


model Category {

  id         String   @id // Financial Category ID from Conta Azul (UUID)
  name       String
  tenantId   String
  parentId   String?
  type       String   // REVENUE / EXPENSE
  entradaDre String?  // Metadata for DRE grouping (e.g., DESPESAS_ADMINISTRATIVAS)
  
  tenant     Tenant   @relation(fields: [tenantId], references: [id])
  budgets    BudgetEntry[]
  realized   RealizedEntry[]
}

model CostCenter {
  id        String   @id // Cost Center ID from Conta Azul (UUID)
  name      String
  tenantId  String
  
  tenant    Tenant   @relation(fields: [tenantId], references: [id])
  budgets   BudgetEntry[]
  realized  RealizedEntry[]
  userAccess UserCostCenterAccess[]
  locks      CostCenterLock[]
}

model CostCenterLock {
  id           String   @id @default(uuid())
  tenantId     String
  costCenterId String
  year         Int
  isLocked     Boolean  @default(false)
  
  // N1/N2 Approval Workflow Fields
  status       String   @default("PENDING") // PENDING, AWAITING_N2, APPROVED, REJECTED
  
  n1ApprovedBy String?
  n1ApprovedAt DateTime?

  n2ApprovedBy String?
  n2ApprovedAt DateTime?

  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  tenant       Tenant     @relation(fields: [tenantId], references: [id])
  costCenter   CostCenter @relation(fields: [costCenterId], references: [id])

  @@unique([tenantId, costCenterId, year])
}



model BudgetEntry {
  id           String   @id @default(uuid())
  tenantId     String
  categoryId   String   
  costCenterId String?  
  month        Int      // 1-12
  year         Int
  amount       Float
  radarAmount  Float?
  isLocked     Boolean  @default(false)
  observation  String?  // Optional justification/observation text
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  tenant       Tenant      @relation(fields: [tenantId], references: [id])
  category     Category    @relation(fields: [categoryId], references: [id])
  costCenter   CostCenter? @relation(fields: [costCenterId], references: [id])

  @@unique([tenantId, categoryId, costCenterId, month, year])
}

model RealizedEntry {
  id           String   @id @default(uuid())
  tenantId     String
  categoryId   String   
  costCenterId String?  
  month        Int      // 1-12
  year         Int
  amount       Float    // Custo/Receita consolidada do Conta Azul
  viewMode     String   @default("competencia") // "caixa" ou "competencia"
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  tenant       Tenant      @relation(fields: [tenantId], references: [id])
  category     Category    @relation(fields: [categoryId], references: [id])
  costCenter   CostCenter? @relation(fields: [costCenterId], references: [id])

  @@unique([tenantId, categoryId, costCenterId, month, year, viewMode])
}

model User {
  id           String     @id @default(uuid())
  name         String
  email        String     @unique
  passwordHash String
  role         Role       @default(GESTOR)
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  tenantAccess     UserTenantAccess[]
  costCenterAccess UserCostCenterAccess[]
}

model UserTenantAccess {
  id        String   @id @default(uuid())
  userId    String
  tenantId  String
  createdAt DateTime @default(now())

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([userId, tenantId])
}

model UserCostCenterAccess {
  id           String   @id @default(uuid())
  userId       String
  costCenterId String
  accessLevel  String   @default("EDITAR") // "LEITOR", "EDITAR", "APROVADOR_N1", "APROVADOR_N2", "APROVADOR_N1_N2"
  createdAt    DateTime @default(now())

  user       User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  costCenter CostCenter @relation(fields: [costCenterId], references: [id], onDelete: Cascade)

  @@unique([userId, costCenterId])
}

enum Role {
  MASTER
  GESTOR
}
