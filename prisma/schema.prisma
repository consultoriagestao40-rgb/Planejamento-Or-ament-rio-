generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("POSTGRES_PRISMA_URL") // Uses connection pooling
}

model Tenant {
  id           String   @id @default(uuid())
  name         String
  cnpj         String   @unique
  accessToken  String?
  refreshToken String?
  tokenExpiresAt DateTime?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  
  budgets      BudgetEntry[]
  categories   Category[]
  costCenters  CostCenter[]
}

model Category {
  id        String   @id // Financial Category ID from Conta Azul (UUID)
  name      String
  tenantId  String
  parentId  String?
  type      String   // REVENUE / EXPENSE
  
  tenant    Tenant   @relation(fields: [tenantId], references: [id])
  budgets   BudgetEntry[]
}

model CostCenter {
  id        String   @id // Cost Center ID from Conta Azul (UUID)
  name      String
  tenantId  String
  
  tenant    Tenant   @relation(fields: [tenantId], references: [id])
  budgets   BudgetEntry[]
}

model BudgetEntry {
  id           String   @id @default(uuid())
  tenantId     String
  categoryId   String   
  costCenterId String?  
  month        Int      // 1-12
  year         Int
  amount       Float
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  tenant       Tenant      @relation(fields: [tenantId], references: [id])
  category     Category    @relation(fields: [categoryId], references: [id])
  costCenter   CostCenter? @relation(fields: [costCenterId], references: [id])

  @@unique([tenantId, categoryId, costCenterId, month, year])
}
